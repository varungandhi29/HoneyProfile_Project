              <Legend wrapperStyle={{ fontSize: '12px', color: '#888888' }} />
              <Bar dataKey="LOW" stackId="a" fill="#A8E063" radius={[0, 0, 0, 0]} />
              <Bar dataKey="MEDIUM" stackId="a" fill="#FFFFFF" radius={[0, 0, 0, 0]} />
