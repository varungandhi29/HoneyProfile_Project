            end_idx = len(content)
            
        block = content[start_idx:end_idx].strip()
        
        # Remove trailing export default if accidentally captured
        idx = block.rfind("export default function HoneyShieldApp")
        if idx != -1 and name != 'HoneyShieldApp':
            block = block[:idx].strip()
            
        blocks[name] = block
    return blocks

